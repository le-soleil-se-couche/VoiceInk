# Normalize all text files to LF in working tree and repository.
* text=auto eol=lf

# Keep Windows shell scripts in CRLF so they execute cleanly on Windows.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.db binary
*.db-shm binary
*.db-wal binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.pdf binary
*.wav binary
*.mp3 binary
*.mp4 binary
